#!/usr/bin/env sh
# Pizza Robot Studios global policy: block commits that contain API key patterns.
# Patterns: Anthropic (sk-ant-), Google/Firebase (AIza), Resend (re_).
PATTERNS="sk-ant-[a-zA-Z0-9_-]{20,}|AIza[0-9A-Za-z_-]{35}|re_[a-zA-Z0-9_-]{20,}"
if git diff --cached | grep -qE "$PATTERNS"; then
  echo "❌ COMMIT BLOCKED: Possible API key detected in staged changes"
  echo "Remove the key, use process.env instead, then retry commit"
  exit 1
fi
